{
  "name": "platform-backend-desktop",
  "description": "Standalone NestJS API for Railway / desktop hosting",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "dev": "pnpm --filter @platform/api dev",
    "start": "pnpm --filter @platform/api start",
    "db:push": "pnpm --filter @platform/database-pg push",
    "seed:live": "node scripts/seed-live.mjs",
    "sync:from-monorepo": "node scripts/sync-from-monorepo.mjs"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
