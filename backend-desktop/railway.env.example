# Paste into Railway → API service → Variables
# Link Postgres first, then add the rest.

# Private/internal Postgres (no egress fees) — do NOT use the public proxy URL here
DATABASE_URL=${{Postgres.DATABASE_URL}}

NODE_ENV=production

JWT_ACCESS_SECRET=dev-access-secret-change-me-min-32-chars-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

SEED_USER_EMAIL=admin@platform.local
SEED_USER_PASSWORD=changeme-please-01

CORS_ORIGINS=http://127.0.0.1:1420,tauri://localhost,https://tauri.localhost,http://tauri.localhost,https://backend-desktop-production-5505.up.railway.app

APP_PUBLIC_URL=https://platformapi-production-39aa.up.railway.app

# Optional SMTP — when unset, invite links are logged to the API console
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=POPS <noreply@yourdomain.com>

# Do NOT set PORT — Railway injects it automatically
