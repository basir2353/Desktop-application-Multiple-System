# Paste into Railway → backend-desktop API service → Variables

DATABASE_URL=${{Postgres.DATABASE_URL}}
NODE_ENV=production

JWT_ACCESS_SECRET=change-me-to-a-random-string-at-least-32-characters
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

SEED_USER_EMAIL=admin@platform.local
SEED_USER_PASSWORD=changeme-please-01

CORS_ORIGINS=http://127.0.0.1:1420,tauri://localhost,https://tauri.localhost,http://tauri.localhost

# Do NOT set PORT — Railway injects it automatically
