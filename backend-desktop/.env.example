# Backend API environment (backend/api)
# Copy: cp backend/.env.example backend/.env

# --- Database ---
# Local: postgresql://platform:platform@localhost:15432/platform
# Railway (API service): DATABASE_URL=${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://platform:platform@localhost:15432/platform

# --- Server ---
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# --- Auth ---
# Generate: openssl rand -base64 32
JWT_ACCESS_SECRET=dev-access-secret-change-me-min-32-chars-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

# --- First-boot seed ---
SEED_USER_EMAIL=admin@platform.local
SEED_USER_PASSWORD=changeme-please-01

# --- CORS ---
CORS_ORIGINS=http://127.0.0.1:1420,tauri://localhost

# --- Invite emails ---
APP_PUBLIC_URL=http://127.0.0.1:1420

# Optional SMTP
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=POPS <noreply@yourdomain.com>
