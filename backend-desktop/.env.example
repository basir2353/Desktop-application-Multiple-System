# Standalone backend-desktop environment
# Copy: cp .env.example .env

DATABASE_URL=postgresql://platform:platform@localhost:15432/platform
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

JWT_ACCESS_SECRET=dev-access-secret-change-me-min-32-chars-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

SEED_USER_EMAIL=admin@platform.local
SEED_USER_PASSWORD=changeme-please-01

CORS_ORIGINS=http://127.0.0.1:1420,tauri://localhost,https://tauri.localhost,http://tauri.localhost
APP_PUBLIC_URL=http://127.0.0.1:1420

# Railway production: use ${{Postgres.DATABASE_URL}} for DATABASE_URL
