# Railway environment variables (paste into API service → Variables)

# Link to your Postgres plugin (replace "Postgres" with your DB service name if different)
DATABASE_URL=${{Postgres.DATABASE_URL}}

NODE_ENV=production

# Generate: openssl rand -base64 32
JWT_ACCESS_SECRET=change-me-min-32-characters-production-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30

SEED_USER_EMAIL=admin@platform.local
SEED_USER_PASSWORD=changeme-please-01

# Comma-separated browser origins (web + desktop Tauri + local dev)
CORS_ORIGINS=https://your-frontend.example.com,http://127.0.0.1:1420,tauri://localhost

APP_PUBLIC_URL=https://your-frontend.example.com

# Do NOT set PORT — Railway sets it automatically
