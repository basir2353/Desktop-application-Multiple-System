{
  "expo": {
    "name": "POPS Waiter",
    "slug": "pops-waiter",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "pops-waiter",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "splash": {
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.platform.pops.waiter"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f172a"
      },
      "package": "com.platform.pops.waiter",
      "permissions": ["INTERNET", "ACCESS_NETWORK_STATE"]
    },
    "plugins": ["expo-router", "expo-secure-store"]
  }
}
