# Build from repository root:
#   docker build -f apps/launcher/Dockerfile.web \
#     --build-arg VITE_API_BASE_URL=https://api.yourdomain.com \
#     -t platform-web .
FROM node:22-bookworm-slim AS build
WORKDIR /app
ARG VITE_API_BASE_URL=http://127.0.0.1:3000
ENV VITE_API_BASE_URL=$VITE_API_BASE_URL
RUN corepack enable && corepack prepare pnpm@9.15.4 --activate
COPY package.json pnpm-workspace.yaml turbo.json ./
COPY pnpm-lock.yaml* ./
COPY packages ./packages
COPY apps/launcher ./apps/launcher
RUN pnpm install --frozen-lockfile=false
RUN pnpm --filter @platform/launcher build:web

FROM nginx:1.27-alpine AS runner
COPY apps/launcher/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/apps/launcher/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
