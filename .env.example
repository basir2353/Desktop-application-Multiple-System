# API (backend/api) — host this service online; clients point VITE_/EXPO_PUBLIC_ URLs here
# Must match docker-compose host port (POSTGRES_HOST_PORT below).
POSTGRES_HOST_PORT=15432
DATABASE_URL=postgresql://platform:platform@localhost:15432/platform
PORT=3000
JWT_ACCESS_SECRET=dev-access-secret-change-me-min-32-chars-long
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30
SEED_USER_EMAIL=admin@platform.local
SEED_USER_PASSWORD=changeme-please-01

# Invite links in emails (launcher dev URL)
APP_PUBLIC_URL=http://127.0.0.1:1420
# Optional SMTP — when unset, invite links are logged to the API console
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=POPS <noreply@yourdomain.com>

# CORS for hosted API (comma-separated browser origins; desktop/mobile skip CORS)
# Railway example: https://your-app.up.railway.app frontend + local dev
# CORS_ORIGINS=https://your-frontend.up.railway.app,http://127.0.0.1:1420

# Clients — web + desktop (apps/launcher), mobile (waiter-mobile)
VITE_API_BASE_URL=http://127.0.0.1:3000
# Sample federated remote (must match where Vite prints, e.g. port 5001 or next if busy)
SAMPLE_MODULE_PORT=5001
VITE_SAMPLE_REMOTE_URL=http://127.0.0.1:5001/assets/remoteEntry.js
