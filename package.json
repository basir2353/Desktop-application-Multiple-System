{
  "name": "platform",
  "description": "Multi-system ERP — single backend, unified frontend (web + desktop), mobile apps",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "dev:stack": "turbo run dev --parallel --filter=@platform/api --filter=@platform/launcher",
    "dev:launcher": "pnpm --filter @platform/launcher dev",
    "dev:web": "pnpm --filter @platform/launcher dev:web",
    "dev:api": "pnpm --filter @platform/api dev",
    "build:web": "pnpm --filter @platform/launcher build:web",
    "build:api": "pnpm --filter @platform/api build",
    "installer:restaurant": "pnpm --filter @platform/launcher build:restaurant",
    "installer:general-store": "pnpm --filter @platform/launcher build:general-store",
    "installer:pharmacy": "pnpm --filter @platform/launcher build:pharmacy",
    "installer:suite": "pnpm --filter @platform/launcher build:suite",
    "installer:windows": "node apps/launcher/scripts/build-windows-installer.mjs",
    "installer:all": "pnpm --filter @platform/launcher build:all-editions",
    "dev:waiter-mobile": "pnpm --filter @platform/waiter-mobile android",
    "dev:waiter-mobile:metro": "pnpm --filter @platform/waiter-mobile dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "db:generate": "pnpm --filter @platform/database-pg generate",
    "db:migrate": "pnpm --filter @platform/database-pg migrate",
    "db:push": "dotenv -e .env -- pnpm --filter @platform/database-pg push",
    "db:studio": "pnpm --filter @platform/database-pg studio"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "overrides": {
      "react": "18.3.1",
      "react-dom": "18.3.1"
    }
  }
}
